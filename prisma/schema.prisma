generator client {
  provider = "prisma-client"
  output = "../generated/prisma"

}

datasource db {
  provider = "postgresql"
}



enum Categoria {
  BOLOS
  DOCINHOS
  SOBREMESAS
}

enum Especificacao {
  CUPCAKE
  CASEIRO
  VULCAO
  ANIVERSARIO
  GOURMET
  FINOS
  BROWNIES
  TRAVESSA
  PAVES
  PALHA
  POTE
}

model Doce {
  id            Int           @id @default(autoincrement())
  nome          String
  categoria     Categoria
  especificacao Especificacao
  imagemUrl     String
  itensCarrinho ItemCarrinho[]
}



model Carrinho {
  id        Int      @id @default(autoincrement())
  sessionId String   @unique
  itens     ItemCarrinho[]
  criadoEm  DateTime @default(now())
}

model ItemCarrinho {
  id           Int      @id @default(autoincrement())
  carrinho     Carrinho @relation(fields: [carrinhoId], references: [id])
  carrinhoId   Int
  doce     Doce  @relation(fields: [doceId], references: [id])
  doceId    Int
  quantidade   Int
  configuracoes Json   
}